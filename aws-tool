#!/usr/bin/env bash
# aws-tool launcher: bootstraps a local .venv on first run, then runs aws_tool.py.
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
VENV="$SCRIPT_DIR/.venv"
REQS="$SCRIPT_DIR/requirements.txt"
PY_ENTRY="$SCRIPT_DIR/aws_tool.py"

if [ ! -x "$VENV/bin/python3" ]; then
  echo "[aws-tool] Setting up Python venv at $VENV ..."
  python3 -m venv "$VENV"
  "$VENV/bin/pip" install --quiet --upgrade pip
  "$VENV/bin/pip" install --quiet -r "$REQS"
  echo "[aws-tool] Venv ready."
fi

exec "$VENV/bin/python3" "$PY_ENTRY" "$@"
